import { Router } from "express";
import { eq, desc } from "drizzle-orm";
import { db, shopsTable, reviewsTable, usersTable } from "@workspace/db";
import {
  RegisterShopBody,
  RegisterShopResponse,
  GetShopParams,
  GetShopResponse,
  UpdateShopParams,
  UpdateShopBody,
  UpdateShopResponse,
  GetShopReviewsParams,
  GetShopReviewsResponse,
  ListShopsQueryParams,
  ListShopsResponse,
} from "@workspace/api-zod";

const router = Router();

function calcDistance(lat1: number, lon1: number, lat2: number, lon2: number): number {
  const R = 6371;
  const dLat = ((lat2 - lat1) * Math.PI) / 180;
  const dLon = ((lon2 - lon1) * Math.PI) / 180;
  const a = Math.sin(dLat / 2) ** 2 + Math.cos((lat1 * Math.PI) / 180) * Math.cos((lat2 * Math.PI) / 180) * Math.sin(dLon / 2) ** 2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
}

function mapShop(shop: typeof shopsTable.$inferSelect, distanceKm?: number) {
  return {
    id: shop.id,
    name: shop.name,
    address: shop.address,
    city: shop.city,
    state: shop.state,
    pincode: shop.pincode,
    phone: shop.phone,
    lat: shop.lat,
    lng: shop.lng,
    operatingHours: shop.operatingHours,
    isOpen: shop.isOpen === "true",
    status: shop.status,
    rating: shop.rating,
    totalOrders: shop.totalOrders,
    distanceKm: distanceKm ?? null,
    createdAt: shop.createdAt,
  };
}

/** GET /shops */
router.get("/shops", async (req, res): Promise<void> => {
  const params = ListShopsQueryParams.safeParse(req.query);
  if (!params.success) {
    res.status(400).json({ error: params.error.message });
    return;
  }

  const { lat, lng, radius = 10, limit = 20 } = params.data;

  const shops = await db.select().from(shopsTable).where(eq(shopsTable.status, "approved")).orderBy(desc(shopsTable.totalOrders)).limit(limit);

  let result = shops.map(shop => {
    const distanceKm = (lat && lng && shop.lat && shop.lng)
      ? calcDistance(lat, lng, shop.lat, shop.lng)
      : null;
    return { ...mapShop(shop, distanceKm ?? undefined), distanceKm };
  });

  if (lat && lng) {
    result = result.filter(s => !s.distanceKm || s.distanceKm <= radius);
    result.sort((a, b) => (a.distanceKm ?? 999) - (b.distanceKm ?? 999));
  }

  const responseData = ListShopsResponse.parse(result);
  res.json(responseData);
});

/** POST /shops */
router.post("/shops", async (req, res): Promise<void> => {
  const parsed = RegisterShopBody.safeParse(req.body);
  if (!parsed.success) {
    res.status(400).json({ error: parsed.error.message });
    return;
  }

  const [shop] = await db.insert(shopsTable).values({
    ownerId: "anonymous",
    name: parsed.data.name,
    address: parsed.data.address,
    city: parsed.data.city,
    state: parsed.data.state ?? null,
    pincode: parsed.data.pincode ?? null,
    phone: parsed.data.phone,
    lat: parsed.data.lat ?? null,
    lng: parsed.data.lng ?? null,
    operatingHours: parsed.data.operatingHours ?? null,
    isOpen: "true",
    status: "pending",
  }).returning();

  const responseData = RegisterShopResponse.parse(mapShop(shop));
  res.status(201).json(responseData);
});

/** GET /shops/:id */
router.get("/shops/:id", async (req, res): Promise<void> => {
  const rawId = Array.isArray(req.params.id) ? req.params.id[0] : req.params.id;
  const params = GetShopParams.safeParse({ id: rawId });
  if (!params.success) {
    res.status(400).json({ error: params.error.message });
    return;
  }

  const shops = await db.select().from(shopsTable).where(eq(shopsTable.id, params.data.id)).limit(1);
  if (!shops.length) {
    res.status(404).json({ error: "Shop not found" });
    return;
  }

  const responseData = GetShopResponse.parse(mapShop(shops[0]));
  res.json(responseData);
});

/** PATCH /shops/:id */
router.patch("/shops/:id", async (req, res): Promise<void> => {
  const rawId = Array.isArray(req.params.id) ? req.params.id[0] : req.params.id;
  const params = UpdateShopParams.safeParse({ id: rawId });
  const body = UpdateShopBody.safeParse(req.body);
  if (!params.success || !body.success) {
    res.status(400).json({ error: "Invalid request" });
    return;
  }

  const updateData: Record<string, unknown> = { updatedAt: new Date() };
  if (body.data.name) updateData.name = body.data.name;
  if (body.data.address) updateData.address = body.data.address;
  if (body.data.phone) updateData.phone = body.data.phone;
  if (body.data.operatingHours !== undefined) updateData.operatingHours = body.data.operatingHours;
  if (body.data.isOpen !== undefined) updateData.isOpen = body.data.isOpen ? "true" : "false";

  const [updated] = await db.update(shopsTable).set(updateData).where(eq(shopsTable.id, params.data.id)).returning();
  if (!updated) {
    res.status(404).json({ error: "Shop not found" });
    return;
  }

  const responseData = UpdateShopResponse.parse(mapShop(updated));
  res.json(responseData);
});

/** GET /shops/:id/reviews */
router.get("/shops/:id/reviews", async (req, res): Promise<void> => {
  const rawId = Array.isArray(req.params.id) ? req.params.id[0] : req.params.id;
  const params = GetShopReviewsParams.safeParse({ id: rawId });
  if (!params.success) {
    res.status(400).json({ error: params.error.message });
    return;
  }

  const reviews = await db.select().from(reviewsTable).where(eq(reviewsTable.shopId, params.data.id)).orderBy(desc(reviewsTable.createdAt)).limit(20);

  const responseData = GetShopReviewsResponse.parse(reviews.map(r => ({
    id: r.id,
    rating: r.rating,
    comment: r.comment,
    createdAt: r.createdAt,
  })));
  res.json(responseData);
});

export default router;
