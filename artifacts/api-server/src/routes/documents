import { Router } from "express";
import { eq } from "drizzle-orm";
import { db, documentsTable } from "@workspace/db";
import {
  UploadDocumentBody,
  UploadDocumentResponse,
  GetDocumentParams,
  GetDocumentResponse,
  DeleteDocumentParams,
  DeleteDocumentResponse,
  GetDocumentSignedUrlParams,
  GetDocumentSignedUrlResponse,
} from "@workspace/api-zod";
import { createHash, randomBytes } from "crypto";

const router = Router();

function generateSignedUrl(docId: string): string {
  const token = randomBytes(32).toString("hex");
  return `${process.env.BASE_URL || ""}/api/documents/${docId}/download?token=${token}`;
}

function generateAuditHash(docId: string, timestamp: Date): string {
  return createHash("sha256")
    .update(`${docId}:${timestamp.toISOString()}:${process.env.SESSION_SECRET}`)
    .digest("hex")
    .substring(0, 16)
    .toUpperCase();
}

/** POST /documents */
router.post("/documents", async (req, res): Promise<void> => {
  const parsed = UploadDocumentBody.safeParse(req.body);
  if (!parsed.success) {
    res.status(400).json({ error: parsed.error.message });
    return;
  }

  const { fileName, fileType, fileSize, fileDataBase64, passwordProtected } = parsed.data;

  // In production: AES-256 encrypt the file data here
  const encryptedData = fileDataBase64 ? `ENCRYPTED:${fileDataBase64.substring(0, 32)}...` : null;
  const encryptionKeyRef = `KEY-${randomBytes(8).toString("hex").toUpperCase()}`;

  // AI detection (simulated — in production: call actual AI service)
  const sensitiveTypes = ["passport", "pan", "aadhaar", "legal", "medical"];
  const detectedType = detectDocumentType(fileName);
  const isSensitive = sensitiveTypes.includes(detectedType);
  const pageCount = Math.floor(fileSize / 50000) + 1;

  const expiresAt = new Date(Date.now() + 24 * 60 * 60 * 1000); // 24h auto-delete

  const [doc] = await db.insert(documentsTable).values({
    fileName,
    fileType,
    fileSize,
    encryptedData,
    encryptionKeyRef,
    status: "active",
    pageCount,
    detectedType,
    isSensitive,
    passwordProtected: passwordProtected ?? false,
    expiresAt,
  }).returning();

  req.log.info({ docId: doc.id, isSensitive }, "Document uploaded");

  const responseData = UploadDocumentResponse.parse({
    id: doc.id,
    fileName: doc.fileName,
    fileType: doc.fileType,
    fileSize: doc.fileSize,
    status: doc.status,
    pageCount: doc.pageCount,
    detectedType: doc.detectedType,
    isSensitive: doc.isSensitive,
    expiresAt: doc.expiresAt,
    deletedAt: doc.deletedAt,
    createdAt: doc.createdAt,
  });
  res.status(201).json(responseData);
});

/** GET /documents/:id */
router.get("/documents/:id", async (req, res): Promise<void> => {
  const rawId = Array.isArray(req.params.id) ? req.params.id[0] : req.params.id;
  const params = GetDocumentParams.safeParse({ id: rawId });
  if (!params.success) {
    res.status(400).json({ error: params.error.message });
    return;
  }

  const docs = await db.select().from(documentsTable).where(eq(documentsTable.id, params.data.id)).limit(1);
  if (!docs.length) {
    res.status(404).json({ error: "Document not found" });
    return;
  }

  const doc = docs[0];
  const responseData = GetDocumentResponse.parse({
    id: doc.id,
    fileName: doc.fileName,
    fileType: doc.fileType,
    fileSize: doc.fileSize,
    status: doc.status,
    pageCount: doc.pageCount,
    detectedType: doc.detectedType,
    isSensitive: doc.isSensitive,
    expiresAt: doc.expiresAt,
    deletedAt: doc.deletedAt,
    createdAt: doc.createdAt,
  });
  res.json(responseData);
});

/** DELETE /documents/:id */
router.delete("/documents/:id", async (req, res): Promise<void> => {
  const rawId = Array.isArray(req.params.id) ? req.params.id[0] : req.params.id;
  const params = DeleteDocumentParams.safeParse({ id: rawId });
  if (!params.success) {
    res.status(400).json({ error: params.error.message });
    return;
  }

  const docs = await db.select().from(documentsTable).where(eq(documentsTable.id, params.data.id)).limit(1);
  if (!docs.length) {
    res.status(404).json({ error: "Document not found" });
    return;
  }

  const deletedAt = new Date();
  const auditHash = generateAuditHash(params.data.id, deletedAt);

  // Cryptographic deletion: clear encrypted data and key reference
  await db.update(documentsTable).set({
    status: "deleted",
    encryptedData: null,
    encryptionKeyRef: null,
    deletedAt,
    auditHash,
  }).where(eq(documentsTable.id, params.data.id));

  req.log.info({ docId: params.data.id }, "Document cryptographically deleted");

  const responseData = DeleteDocumentResponse.parse({
    documentId: params.data.id,
    deletedAt,
    message: "File has been permanently and cryptographically deleted. The encryption key has been destroyed.",
    auditHash,
  });
  res.json(responseData);
});

/** GET /documents/:id/signed-url */
router.get("/documents/:id/signed-url", async (req, res): Promise<void> => {
  const rawId = Array.isArray(req.params.id) ? req.params.id[0] : req.params.id;
  const params = GetDocumentSignedUrlParams.safeParse({ id: rawId });
  if (!params.success) {
    res.status(400).json({ error: params.error.message });
    return;
  }

  const docs = await db.select().from(documentsTable).where(eq(documentsTable.id, params.data.id)).limit(1);
  if (!docs.length) {
    res.status(404).json({ error: "Document not found" });
    return;
  }

  const doc = docs[0];
  if (doc.status === "deleted") {
    res.status(410).json({ error: "Document has been deleted" });
    return;
  }

  const url = generateSignedUrl(params.data.id);
  const expiresAt = new Date(Date.now() + 5 * 60 * 1000); // 5 minute URL

  const responseData = GetDocumentSignedUrlResponse.parse({
    url,
    expiresAt,
    accessCount: 1,
  });
  res.json(responseData);
});

function detectDocumentType(fileName: string): string {
  const lower = fileName.toLowerCase();
  if (lower.includes("passport")) return "passport";
  if (lower.includes("pan") || lower.includes("pancard")) return "pan";
  if (lower.includes("aadhaar") || lower.includes("aadhar")) return "aadhaar";
  if (lower.includes("invoice") || lower.includes("bill")) return "invoice";
  if (lower.includes("resume") || lower.includes("cv")) return "resume";
  if (lower.includes("legal") || lower.includes("agreement") || lower.includes("contract")) return "legal";
  if (lower.includes("medical") || lower.includes("prescription") || lower.includes("report")) return "medical";
  return "general";
}

export default router;
